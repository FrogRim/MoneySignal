MINIAPP_HOST=app.localhost
PIPELINE_HOST=api.localhost
MINIAPP_PIPELINE_BASE_URL=http://api.localhost:8080

PIPELINE_ENV=production
PIPELINE_BRAIN_BASE_URL=http://brain:8000
PIPELINE_INTERNAL_REBUILD_TOKEN=change-me
PIPELINE_FEED_STORE_PATH=/data/feed-store.json
PIPELINE_SESSION_STATUS=active

BRAIN_REQUEST_ID_HEADER_NAME=x-request-id
BRAIN_CORS_ALLOW_ORIGINS=
BRAIN_CORS_ALLOW_CREDENTIALS=false
BRAIN_TRUSTED_HOSTS=brain,localhost,127.0.0.1
BRAIN_RATE_LIMIT_ENABLED=false
BRAIN_RATE_LIMIT_TRUST_X_FORWARDED_FOR=false
BRAIN_RATE_LIMIT_TRUSTED_PROXY_CLIENTS=
BRAIN_RATE_LIMIT_WINDOW_SECONDS=60
BRAIN_RATE_LIMIT_MAX_REQUESTS=60
BRAIN_BRIEFING_THRESHOLD=0.55
BRAIN_INSTANT_PUSH_THRESHOLD=0.8
BRAIN_SPECIALIST_CONCURRENCY_LIMIT=4
BRAIN_PER_AGENT_TIMEOUT_MS=3000
